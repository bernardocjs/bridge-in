generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id   String @id @default(uuid())
  name String

  magicLinkSlug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships CompanyMembership[]
  reports     Report[]
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membership       CompanyMembership?
  reviewedRequests CompanyMembership[] @relation("ReviewedBy")
}

model CompanyMembership {
  id String @id @default(uuid())

  userId    String
  companyId String
  role      MemberRole       @default(MEMBER)
  status    MembershipStatus @default(PENDING)

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewer    User?     @relation("ReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([companyId, status])
}

model Report {
  id String @id @default(uuid())

  title   String @db.VarChar(255)
  content String @db.Text

  status   ReportStatus   @default(OPEN)
  priority ReportPriority @default(MEDIUM)

  reporterContact String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
}
