generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Company {
  id   String @id @default(uuid())
  name String

  /// Rotatable token used for anonymous report submissions and user onboarding.
  magicLinkSlug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  reports Report[]

  @@index([magicLinkSlug])
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Report {
  id String @id @default(uuid())

  title   String @db.VarChar(255)
  content String @db.Text

  status   ReportStatus   @default(OPEN)
  priority ReportPriority @default(MEDIUM)

  /// Optional contact for confidential (non-anonymous) reports.
  reporterContact String?

  /// Linked to Company (not User) so reports survive user deletion.
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}
