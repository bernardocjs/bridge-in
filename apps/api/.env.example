# Database
# Em produção (Neon): use a URL do pooler no DATABASE_URL e a URL direta no DIRECT_URL
# Em desenvolvimento: ambas podem ser iguais
DATABASE_URL="postgresql://bridge:bridge@localhost:5432/bridge_in"
DIRECT_URL="postgresql://bridge:bridge@localhost:5432/bridge_in"

# App
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Auth
JWT_SECRET="super-secret-change-me"
JWT_EXPIRATION="1d"

# Logging (fatal | error | warn | info | debug | trace)
LOG_LEVEL="debug"
